@using ClubGear.Plugin.Contracts
@model (PluginPageDefinition Definition, IReadOnlyList<IReadOnlyDictionary<string, string?>> Rows, string ModuleId, string? FilterValue)
@{
    var definition = Model.Definition;
    var rows = Model.Rows;
    var moduleId = Model.ModuleId;
    var filterValue = Model.FilterValue;
    ViewData["Title"] = definition.Title;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@definition.Title</h2>
    </div>

    @if (definition.FilterPlaceholder is not null)
    {
        <form method="get" class="mb-3">
            <div class="input-group">
                <input type="text" class="form-control" name="q"
                       value="@filterValue"
                       placeholder="@definition.FilterPlaceholder" />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Suchen
                </button>
                @if (!string.IsNullOrEmpty(filterValue))
                {
                    <a href="@Url.Action("Index", new { moduleId, pageKey = definition.PageKey })"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-x"></i>
                    </a>
                }
            </div>
        </form>
    }

    @{
        var listCommands = definition.Commands.Where(c => !c.RequiresEntityKey).ToList();
    }
    @if (listCommands.Count > 0)
    {
        <div class="mb-3">
            @foreach (var cmd in listCommands)
            {
                var schemaJson = System.Text.Json.JsonSerializer.Serialize(cmd.Schema ?? []);
                <button type="button"
                        class="btn btn-primary me-1"
                        data-plugin-page-action="@cmd.Key"
                        data-module-id="@moduleId"
                        data-page-key="@definition.PageKey"
                        data-command-key="@cmd.Key"
                        data-command-label="@cmd.Label"
                        data-command-schema="@schemaJson">
                    @if (!string.IsNullOrEmpty(cmd.Icon))
                    {
                        <i class="bi @cmd.Icon me-1"></i>
                    }
                    @cmd.Label
                </button>
            }
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            @foreach (var col in definition.Columns)
                            {
                                <th>@col.Label</th>
                            }
                            @{
                                var rowCommands = definition.Commands.Where(c => c.RequiresEntityKey).ToList();
                            }
                            @if (rowCommands.Count > 0)
                            {
                                <th>Aktionen</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (rows.Count == 0)
                        {
                            <tr>
                                <td colspan="@(definition.Columns.Count + (rowCommands.Count > 0 ? 1 : 0))"
                                    class="text-center text-muted py-4">
                                    Keine Eintraege vorhanden.
                                </td>
                            </tr>
                        }
                        @foreach (var row in rows)
                        {
                            <tr>
                                @foreach (var col in definition.Columns)
                                {
                                    <td>@(row.TryGetValue(col.Key, out var cellVal) ? cellVal ?? "" : "")</td>
                                }
                                @if (rowCommands.Count > 0)
                                {
                                    var entityKey = row.TryGetValue(definition.EntityKeyColumn, out var ek) ? ek ?? "" : "";
                                    <td>
                                        @foreach (var cmd in rowCommands)
                                        {
                                            var schemaJson = System.Text.Json.JsonSerializer.Serialize(cmd.Schema ?? []);
                                            <a href="@Url.Action("Detail", new { moduleId, pageKey = definition.PageKey, entityKey })"
                                               class="btn btn-sm btn-outline-primary me-1"
                                               style="display:none" data-detail-link>Detail</a>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary me-1"
                                                    data-plugin-page-action="@cmd.Key"
                                                    data-module-id="@moduleId"
                                                    data-page-key="@definition.PageKey"
                                                    data-command-key="@cmd.Key"
                                                    data-entity-key="@entityKey"
                                                    data-command-label="@cmd.Label"
                                                    data-command-schema="@schemaJson">
                                                @if (!string.IsNullOrEmpty(cmd.Icon))
                                                {
                                                    <i class="bi @cmd.Icon me-1"></i>
                                                }
                                                @cmd.Label
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<partial name="~/Views/PluginPage/_PluginPageActionModal.cshtml" />
