@model ClubGear.Models.Member
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var defaultAddress = Model.Addresses.FirstOrDefault(a => a.IsDefault) ?? Model.Addresses.FirstOrDefault() ?? new ClubGear.Models.MemberAddress { IsDefault = true };
    var membershipTypes = (ViewData["MembershipTypes"] as IReadOnlyList<ClubGear.Models.MembershipType>) ?? new List<ClubGear.Models.MembershipType>();
}

<div class="row g-3">
    <div class="col-md-3">
        <label asp-for="MemberNumber" class="form-label"></label>
        <input asp-for="MemberNumber" class="form-control" placeholder="Automatisch vergeben wenn leer" />
        <span asp-validation-for="MemberNumber" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Title" class="form-label">Titel</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="DateOfBirth" class="form-label">Geburtsdatum</label>
        <input asp-for="DateOfBirth" type="date" class="form-control" />
        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Gender" class="form-label">Geschlecht</label>
        <input asp-for="Gender" class="form-control" />
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    <div class="col-md-5">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="MembershipTypeId" class="form-label">Mitgliedsart</label>
        <select asp-for="MembershipTypeId" class="form-select member-type-toggle" id="MembershipTypeId"
                asp-items="@(new SelectList(membershipTypes, "Id", "Name"))">
            <option value="">-- Keine --</option>
        </select>
        <span asp-validation-for="MembershipTypeId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <partial name="_MemberMetadataFields" model="Model" />
    </div>

    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </div>

    <div class="col-12">
        <h2 class="h6 mt-2">Hauptadresse</h2>
    </div>
    <input type="hidden" name="Addresses[0].Id" value="@defaultAddress.Id" />
    <input type="hidden" name="Addresses[0].IsDefault" value="true" />
    <div class="col-md-6">
        <label class="form-label" for="AddressStreet">Strasse</label>
        <input id="AddressStreet" class="form-control" name="Addresses[0].Street" value="@defaultAddress.Street" />
    </div>
    <div class="col-md-2">
        <label class="form-label" for="AddressPostalCode">PLZ</label>
        <input id="AddressPostalCode" class="form-control" name="Addresses[0].PostalCode" value="@defaultAddress.PostalCode" />
    </div>
    <div class="col-md-4">
        <label class="form-label" for="AddressCity">Stadt</label>
        <input id="AddressCity" class="form-control" name="Addresses[0].City" value="@defaultAddress.City" />
    </div>
    <div class="col-md-4">
        <label class="form-label" for="AddressCountry">Land</label>
        <input id="AddressCountry" class="form-control" name="Addresses[0].Country" value="@defaultAddress.Country" />
    </div>
</div>
