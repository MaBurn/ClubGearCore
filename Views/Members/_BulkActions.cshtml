@model IEnumerable<ClubGear.Models.Member>

<div class="members-bulk-card cg-panel shadow-sm">
    <div class="members-bulk-card__copy">
        <p class="members-bulk-card__eyebrow">Bulk-Aktionen</p>
        <h2 class="members-bulk-card__title">Serienaktionen auf sichtbare Datensaetze</h2>
    </div>

    <div class="members-bulk-card__controls">
        <label class="form-check mb-0">
            <input id="member-select-all" class="form-check-input" type="checkbox" data-member-select-all />
            <span class="form-check-label">Alle sichtbaren Mitglieder auswaehlen</span>
        </label>
        <button type="submit" form="member-bulk-delete-form" class="btn btn-outline-danger btn-lg">
            Ausgewaehlte inaktive Mitglieder loeschen
        </button>
    </div>
</div>

<script>
    (function () {
        const selectAll = document.getElementById("member-select-all");
        if (!selectAll) {
            return;
        }

        selectAll.addEventListener("change", function () {
            const checkboxes = document.querySelectorAll("input[data-member-bulk-select]");
            checkboxes.forEach(function (checkbox) {
                checkbox.checked = selectAll.checked;
            });
        });
    })();
</script>
