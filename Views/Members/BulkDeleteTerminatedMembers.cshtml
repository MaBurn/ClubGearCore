@model IEnumerable<ClubGear.Models.Member>
@{
    ViewData["Title"] = "Inaktive Mitglieder loeschen";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1">Inaktive Mitglieder loeschen</h1>
            <p class="text-muted mb-0">Uebernommen aus der ClubManager-Idee "Bulk Delete": Auswahl + Massenloeschung.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Zurueck</a>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-success">Keine inaktiven Mitglieder vorhanden.</div>
    }
    else
    {
        <form asp-action="BulkDeleteTerminatedMembers" method="post" onsubmit="return confirm('Ausgewaehlte Mitglieder wirklich dauerhaft loeschen?');">
            @Html.AntiForgeryToken()

            <div class="card shadow-sm mb-3">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="toggleAll(true)">Alle waehlen</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleAll(false)">Auswahl aufheben</button>
                    </div>
                    <button type="submit" class="btn btn-danger">Ausgewaehlte loeschen</button>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th style="width:40px;"></th>
                                <th>Nr.</th>
                                <th>Name</th>
                                <th>E-Mail</th>
                                <th>Beigetreten</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model.OrderBy(m => m.LastName).ThenBy(m => m.FirstName))
                            {
                                <tr>
                                    <td><input class="form-check-input member-check" type="checkbox" name="selectedMemberIds" value="@member.Id" /></td>
                                    <td>@member.MemberNumber</td>
                                    <td>@member.FullName</td>
                                    <td>@member.Email</td>
                                    <td>@member.JoinedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </form>
    }
</div>

<script>
function toggleAll(state) {
    document.querySelectorAll('.member-check').forEach(cb => { cb.checked = state; });
}
</script>
