@model IReadOnlyList<ClubGear.Models.PluginAdmin.PluginAdminStatusViewModel>

<div class="plugin-admin-list" data-plugin-admin-table>
    @if (Model.Count == 0)
    {
        <div class="plugin-admin-empty cg-panel">
            <div class="plugin-admin-empty__icon" aria-hidden="true">
                <i class="bi bi-box-seam"></i>
            </div>
            <h3>Noch keine Plugins installiert</h3>
            <p>Nutze einen der Installationswege weiter unten, um ClubGear zu erweitern.</p>
        </div>
    }
    else
    {
        @foreach (var plugin in Model)
        {
            var healthy = plugin.IsContractCompatible
                && string.IsNullOrWhiteSpace(plugin.LastError)
                && (!plugin.IsActive || plugin.IsRuntimeRegistered);
            var contributionCount = plugin.RouteCount
                + plugin.ServiceCount
                + plugin.MemberProviderCount
                + plugin.BackgroundJobCount
                + plugin.NavEntryCount
                + plugin.AuditSinkCount;

            <article class="plugin-admin-plugin cg-panel @(!healthy ? "plugin-admin-plugin--attention" : null)" data-plugin-module-id="@plugin.ModuleId">
                <div class="plugin-admin-plugin__main">
                    <div class="plugin-admin-plugin__identity">
                        <div class="plugin-admin-plugin__mark" aria-hidden="true">
                            <i class="bi @(plugin.IsRuntimeRegistered ? "bi-plugin" : "bi-box")"></i>
                        </div>
                        <div class="plugin-admin-plugin__name">
                            <div class="plugin-admin-plugin__title-row">
                                <h3 class="plugin-admin-plugin__title">@plugin.DisplayName</h3>
                                <span class="plugin-admin-version">v@plugin.PluginVersion</span>
                            </div>
                            <code class="plugin-admin-plugin__id">@plugin.ModuleId</code>
                            <div class="plugin-admin-plugin__meta">
                                <span>@plugin.Author</span>
                                <span aria-hidden="true">·</span>
                                <span>@plugin.Category</span>
                                <span aria-hidden="true">·</span>
                                <span>@plugin.Source</span>
                            </div>
                        </div>
                    </div>

                    <div class="plugin-admin-plugin__statuses">
                        <span class="plugin-admin-pill @(plugin.IsActive ? "plugin-admin-pill--active" : "plugin-admin-pill--neutral")">
                            <span class="plugin-admin-pill__dot" aria-hidden="true"></span>
                            @(plugin.IsActive ? "Aktiviert" : "Deaktiviert")
                        </span>
                        <span class="plugin-admin-pill @(plugin.IsRuntimeRegistered ? "plugin-admin-pill--runtime" : "plugin-admin-pill--neutral")">
                            @(plugin.IsRuntimeRegistered ? "Runtime geladen" : "Nicht geladen")
                        </span>
                        <span class="plugin-admin-pill @(plugin.IsContractCompatible ? "plugin-admin-pill--compatible" : "plugin-admin-pill--danger")">
                            @(plugin.IsContractCompatible ? "Kompatibel" : "Inkompatibel")
                        </span>
                    </div>
                </div>

                <div class="plugin-admin-plugin__facts">
                    <div>
                        <span class="plugin-admin-plugin__fact-value">@contributionCount</span>
                        <span class="plugin-admin-plugin__fact-label">Beiträge</span>
                    </div>
                    <div>
                        <span class="plugin-admin-plugin__fact-value">@plugin.AppliedMigrationCount</span>
                        <span class="plugin-admin-plugin__fact-label">Migrationen</span>
                    </div>
                    <div>
                        <span class="plugin-admin-plugin__fact-value">@plugin.RequiredCoreVersion</span>
                        <span class="plugin-admin-plugin__fact-label">Core-Version</span>
                    </div>
                    <div>
                        <span class="plugin-admin-plugin__fact-value">@(plugin.InstalledAtUtc?.ToLocalTime().ToString("dd.MM.yy") ?? "–")</span>
                        <span class="plugin-admin-plugin__fact-label">Installiert</span>
                    </div>
                </div>

                @if (!healthy)
                {
                    <div class="plugin-admin-plugin__warning">
                        <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                        <span>
                            @if (!string.IsNullOrWhiteSpace(plugin.LastError))
                            {
                                @plugin.LastError
                            }
                            else if (!plugin.IsContractCompatible)
                            {
                                @(plugin.ContractCompatibilityReason ?? "Der Plugin-Vertrag ist nicht kompatibel.")
                            }
                            else
                            {
                                @:Das Plugin ist aktiviert, wurde aber nicht in die Runtime geladen.
                            }
                        </span>
                    </div>
                }

                <div class="plugin-admin-plugin__footer">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Detail" asp-route-moduleId="@plugin.ModuleId">
                        Details
                    </a>

                    <div class="plugin-admin-plugin__actions">
                        @if (!plugin.IsInstalled)
                        {
                            <span class="text-muted small">Nur Runtime-Eintrag</span>
                        }
                        else if (plugin.IsActive)
                        {
                            <form asp-action="Deactivate" method="post" data-plugin-admin-action data-confirm="Plugin wirklich deaktivieren?">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="moduleId" value="@plugin.ModuleId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deaktivieren</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Activate" method="post" data-plugin-admin-action data-confirm-if-technical="@plugin.Category">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="moduleId" value="@plugin.ModuleId" />
                                <button type="submit" class="btn btn-sm btn-primary">Aktivieren</button>
                            </form>

                            <form asp-action="Delete" method="post" class="plugin-admin-delete-form" data-plugin-admin-action data-confirm="Plugin wirklich löschen?">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="moduleId" value="@plugin.ModuleId" />
                                <label class="form-check plugin-admin-remove-data" title="Auch gespeicherte Plugin-Daten entfernen">
                                    <input class="form-check-input" type="checkbox" name="removeData" value="true" />
                                    <span class="form-check-label">Daten löschen</span>
                                </label>
                                <button type="submit" class="btn btn-sm btn-link text-danger">Deinstallieren</button>
                            </form>
                        }
                    </div>
                </div>
            </article>
        }
    }
</div>
