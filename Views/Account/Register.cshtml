@{
    ViewData["Title"] = "Registrieren";
}

<div class="cg-page cg-page--account">
<section class="cg-page-section">
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm cg-panel">
            <div class="card-body p-4">
                <h1 class="h3 mb-4 cg-page-title">Registrieren</h1>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label for="fullName" class="form-label">Vollstaendiger Name</label>
                        <input id="fullName" name="fullName" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">E-Mail</label>
                        <input id="email" name="email" class="form-control" type="email" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Passwort</label>
                        <input id="password" name="password" class="form-control" type="password" minlength="8" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Konto erstellen</button>
                </form>
            </div>
        </div>
    </div>
</div>
</section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
