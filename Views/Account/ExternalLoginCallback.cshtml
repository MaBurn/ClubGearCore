@model ClubGear.Services.Abstractions.ExternalLoginOutcome
@{
    ViewData["Title"] = "Externe Anmeldung";
}

<h2>@ViewData["Title"]</h2>

@if (Model?.Status == ClubGear.Services.Abstractions.ExternalLoginStatus.NoLinkedMember)
{
    <div class="alert alert-warning">
        <p>
            Ihr externes Konto (<strong>@ViewData["ExternalUserId"]</strong>) ist noch mit keinem
            ClubGear-Mitgliedskonto verkn&uuml;pft.
        </p>
        <p>
            Bitte melden Sie sich zun&auml;chst mit Ihrem bestehenden Passwort an oder wenden Sie sich
            an Ihren Administrator, um die Verkn&uuml;pfung einzurichten.
        </p>
    </div>

    <a asp-action="Login" asp-controller="Account" class="btn btn-primary">Zur Anmeldung</a>
}
else
{
    <div class="alert alert-danger">
        <p>Bei der externen Anmeldung ist ein Fehler aufgetreten.</p>
        @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
        {
            <p>@Model.ErrorMessage</p>
        }
    </div>

    <a asp-action="Login" asp-controller="Account" class="btn btn-secondary">Zur&uuml;ck zur Anmeldung</a>
}
