@using ClubGear.Services.Abstractions
@{
    ViewData["Title"] = "Anmelden";
    var activeProviders = ViewData["ActiveProviders"] as IReadOnlyList<ExternalProviderInfo>
                          ?? Array.Empty<ExternalProviderInfo>();
}

<div class="cg-page cg-page--account">
<section class="cg-page-section">
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm cg-panel">
            <div class="card-body p-4">
                <h1 class="h3 mb-4 cg-page-title">Anmelden</h1>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label for="email" class="form-label">E-Mail</label>
                        <input id="email" name="email" class="form-control" type="email" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Passwort</label>
                        <input id="password" name="password" class="form-control" type="password" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Anmelden</button>
                </form>

                @if (activeProviders.Count > 0)
                {
                    <hr class="my-3" />
                    <div class="d-grid gap-2">
                        @foreach (var provider in activeProviders)
                        {
                            <a asp-controller="Account"
                               asp-action="ExternalLoginChallenge"
                               asp-route-provider="@provider.ProviderKey"
                               asp-route-returnUrl="@ViewData["ReturnUrl"]"
                               class="btn btn-outline-secondary">
                                Mit @provider.DisplayName anmelden
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
</section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
